# Google Calendar Integration
# Required for bidirectional sync with Google Calendar
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXT_PUBLIC_GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Make (Zapier alternative) Webhook Integration
# Endpoint where Make will send data or where app will push events
NEXT_PUBLIC_MAKE_WEBHOOK_URL=https://hooks.make.com/your_custom_hook_url
MAKE_API_KEY=your_make_api_key_here

# WhatsApp Business API (Meta)
# For real WhatsApp messaging integration
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Backend & Database
# For future backend / PostgreSQL migration
DATABASE_URL=postgresql://user:password@localhost:5432/barbershop_ia
API_BASE_URL=http://localhost:3000/api

# Application Config
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_TIMEZONE=America/Mexico_City

# Sync Configuration
# How often to poll external calendars (minutes)
SYNC_POLL_INTERVAL=5
# Enable webhook-based sync (Google Calendar Watch API)
ENABLE_WATCH_CHANNELS=false
